## Core Data Models (Convex Schema)

```typescript
// Workspaces — one per HubSpot portal
workspaces: {
  hubspotPortalId: string
  name: string
  creditBalance: number
  polarSubscriptionId: string
  plan: "starter" | "growth" | "agency"
  autoApproveReview: boolean  // Solo workflow setting
  createdAt: number
}

// Users — unlimited seats per workspace
users: {
  workspaceId: Id<"workspaces">
  clerkUserId: string
  email: string
  role: "admin" | "member"
  createdAt: number
}

// Content Briefs — the parent entity for a piece of content.
// Phase progresses forward only; each sub-entity (research, interview, draft) tracks its own internal status.
briefs: {
  workspaceId: Id<"workspaces">
  createdBy: Id<"users">
  contentType: "blog_post" | "case_study" | "customer_story" | "landing_page" | "email" | "guide" | "sales_collateral" | "web_page"
  title: string
  topic: string
  keywords: string[]
  toneOfVoice: string
  formattingRules?: string
  sources: string[]
  customQuestions: string[]

  // Language — two independent fields
  interviewerLanguage: string   // "en", "no", "sv", "de", "es" — drives Deepgram + ElevenLabs
  outputLanguage: string        // Language of the final written draft — drives Claude generation

  // Phase tracking
  phase: "brief" | "research" | "outline" | "interview" | "draft" | "edit" | "review" | "pushed"
  briefReadyAt?: number
  researchApprovedAt?: number
  outlineApprovedAt?: number
  reviewApprovedBy?: Id<"users">
  reviewApprovedAt?: number

  createdAt: number
}

// Research notes — generated in Research phase, approved before Outline
research: {
  briefId: Id<"briefs">
  workspaceId: Id<"workspaces">
  notes: string               // Markdown — key angles, SERP findings, competitor gaps, source summaries
  keywordAnalysis?: string
  status: "generating" | "ready" | "approved"
  creditsConsumed: number
  createdAt: number
}

// Outlines — H2/H3 structure approved before Interview
outlines: {
  briefId: Id<"briefs">
  workspaceId: Id<"workspaces">
  structure: string           // Markdown outline
  status: "generating" | "ready" | "approved"
  createdAt: number
}

// Interview Sessions
interviews: {
  briefId: Id<"briefs">
  workspaceId: Id<"workspaces">
  guestTokenHash: string      // Hashed — raw token returned once at creation
  guestEmail?: string
  guestName?: string
  consentedAt?: number        // GDPR consent timestamp
  status: "pending" | "in_progress" | "completed" | "expired"
  audioStorageKey?: string    // Cloudflare R2 key
  transcript?: string
  creditsConsumed: number
  interviewerLanguage: string // Copied from brief at link generation time
  startedAt?: number
  completedAt?: number
  expiresAt: number
}

// Generated Drafts — includes SEO/AEO metadata
drafts: {
  briefId: Id<"briefs">
  interviewId: Id<"interviews">
  workspaceId: Id<"workspaces">
  content: string             // Markdown / HTML
  title: string
  metaDescription?: string
  slug?: string
  tocEnabled: boolean
  aeoEnabled: boolean
  schemaMarkup?: string       // JSON-LD (Article / FAQ / HowTo)
  internalLinkSuggestions: { anchorText: string; targetDraftId: Id<"drafts"> }[]
  status: "generating" | "ready" | "edited" | "approved" | "pushed_to_hubspot"
  hubspotContentId?: string
  hubspotContentType?: string
  outputLanguage: string
  createdAt: number
}

// Credit Ledger
creditTransactions: {
  workspaceId: Id<"workspaces">
  type: "purchase" | "research" | "interview" | "generation" | "refund"
  amount: number              // negative = consumed
  referenceId?: string        // researchId, interviewId, or draftId
  description: string
  createdAt: number
}
```


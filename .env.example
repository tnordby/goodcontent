# --- Clerk (Next.js) ---
# Publishable key is required for builds that prerender Clerk components.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

# Server secret for Clerk server usage (recommended in all deployed environments).
CLERK_SECRET_KEY=

# Used by Convex auth config (`convex/auth.config.ts`).
# Typically looks like: https://<your-subdomain>.clerk.accounts.dev
CLERK_JWT_ISSUER_DOMAIN=

# Clerk webhook signing secret (`convex/http.ts` validates Svix signatures).
CLERK_WEBHOOK_SECRET=

# Clerk hosted sign-in + redirects (recommended for custom `/sign-in` routes).
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# --- Convex (Next.js browser client) ---
# Cloud URL from the Convex dashboard (ends with `.convex.cloud`).
NEXT_PUBLIC_CONVEX_URL=

# Optional: Convex “site” URL (ends with `.convex.site`) if you use HTTP actions from the browser.
# NEXT_PUBLIC_CONVEX_SITE_URL=

# --- Site metadata (Open Graph / absolute URLs) ---
# Production canonical URL, e.g. https://goodcontent.ai
NEXT_PUBLIC_SITE_URL=

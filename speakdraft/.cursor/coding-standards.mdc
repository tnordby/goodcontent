## Convex Conventions

```typescript
// ✅ Always validate auth in mutations and sensitive queries
export const createBrief = mutation({
  args: { title: v.string(), contentType: v.string() },
  handler: async (ctx, args) => {
    const identity = await ctx.auth.getUserIdentity()
    if (!identity) throw new Error("Unauthenticated")
    // ...
  }
})

// ✅ Use internal functions for sensitive logic
export const deductCredits = internalMutation({
  args: { workspaceId: v.id("workspaces"), amount: v.number() },
  handler: async (ctx, { workspaceId, amount }) => {
    // credit deduction logic — not callable from client
  }
})

// ✅ Always index fields you query by
// In schema.ts:
briefs: defineTable({
  workspaceId: v.id("workspaces"),
  status: v.string(),
  createdAt: v.number(),
}).index("by_workspace", ["workspaceId"])
  .index("by_workspace_status", ["workspaceId", "status"])
```


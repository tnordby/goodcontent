## Component Conventions

```typescript
// ✅ Props interface always defined above component
interface BriefCardProps {
  brief: Brief
  onEdit: (id: Id<"briefs">) => void
}

export function BriefCard({ brief, onEdit }: BriefCardProps) {
  return (...)
}

// ✅ Use shadcn/ui primitives — never roll custom UI for standard elements
import { Button } from "@/components/ui/button"
import { Card, CardHeader, CardContent } from "@/components/ui/card"
import { Select, SelectTrigger, SelectContent, SelectItem } from "@/components/ui/select"

// ✅ Tailwind only — no inline styles, no CSS modules
// ✅ Use cn() utility for conditional classes
import { cn } from "@/lib/utils"
<div className={cn("rounded-lg p-4", isActive && "border-2 border-primary")} />
```


## Next.js App Router

```typescript
// ✅ Server Component — fetch from Convex server-side
export default async function BriefsPage() {
  const briefs = await fetchQuery(api.briefs.listByWorkspace, { workspaceId })
  return <BriefList briefs={briefs} />
}

// ✅ Client Component — only when needed
"use client"
export function InterviewRoom({ token }: { token: string }) {
  const interview = useQuery(api.interviews.getByToken, { token })
  // ... realtime subscriptions
}

// ✅ Route handlers — thin, delegate to Convex or lib functions
// /app/api/hubspot/callback/route.ts
export async function GET(req: Request) {
  const code = new URL(req.url).searchParams.get("code")
  await exchangeHubSpotCode(code) // lib/hubspot.ts
  redirect("/dashboard/settings")
}
```


## TypeScript

```typescript
// ✅ Good — explicit return type, typed params
export async function generateQuestions(
  brief: Brief,
  contentType: ContentType
): Promise<string[]> { ... }

// ❌ Bad — implicit any, no return type
export async function generateQuestions(brief, contentType) { ... }

// ✅ Use Convex Id types for references
import { Id } from "../convex/_generated/dataModel"
type BriefId = Id<"briefs">

// ✅ Use discriminated unions for status
type InterviewStatus =
  | { status: "pending" }
  | { status: "in_progress"; startedAt: number }
  | { status: "completed"; transcript: string; completedAt: number }
  | { status: "expired" }
```


## API Clients (ElevenLabs, Deepgram, Anthropic)

```typescript
// ✅ All API clients instantiated in /lib — never inline
// lib/elevenlabs.ts
import { ElevenLabsClient } from "elevenlabs"
export const elevenlabs = new ElevenLabsClient({
  apiKey: process.env.ELEVENLABS_API_KEY!
})

// ✅ Always use Flash v2.5 for real-time interview TTS
export async function synthesiseSpeech(text: string, language: string) {
  return elevenlabs.textToSpeech.convert(VOICE_ID, {
    text,
    model_id: "eleven_flash_v2_5",
    output_format: "mp3_44100_128"
  })
}

// ✅ Deepgram — always use streaming WebSocket for live interviews
// lib/deepgram.ts
import { createClient, LiveTranscriptionEvents } from "@deepgram/sdk"
export const deepgram = createClient(process.env.DEEPGRAM_API_KEY!)
```

